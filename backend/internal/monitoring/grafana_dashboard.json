{
  "title": "Coindistro - API Overview",
  "uid": "coindistro-api",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["coindistro", "api"],
  "schemaVersion": 36,
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "graph",
      "span": 6,
      "targets": [
        {
          "expr": "rate(coindistro_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "title": "HTTP Request Duration (P99)",
      "type": "graph",
      "span": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(coindistro_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "title": "Database Query Duration",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "rate(coindistro_database_query_duration_seconds_sum[5m]) / rate(coindistro_database_query_duration_seconds_count[5m])",
          "legendFormat": "avg: {{operation}}"
        }
      ]
    },
    {
      "title": "Redis Command Latency",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "rate(coindistro_redis_command_duration_seconds_sum[5m]) / rate(coindistro_redis_command_duration_seconds_count[5m])",
          "legendFormat": "{{command}}"
        }
      ]
    },
    {
      "title": "System Memory Usage",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "coindistro_system_memory_usage_bytes",
          "legendFormat": "Memory"
        }
      ]
    },
    {
      "title": "Goroutines",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "coindistro_system_goroutines_total",
          "legendFormat": "Goroutines"
        }
      ]
    },
    {
      "title": "Error Rate by Status Code",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "rate(coindistro_http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx errors"
        },
        {
          "expr": "rate(coindistro_http_requests_total{status=~\"4..\"}[5m])",
          "legendFormat": "4xx errors"
        }
      ]
    },
    {
      "title": "Worker Queue Depth",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "coindistro_worker_queue_depth",
          "legendFormat": "{{pool}}"
        }
      ]
    },
    {
      "title": "Database Errors",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "rate(coindistro_database_errors_total[5m])",
          "legendFormat": "{{operation}}"
        }
      ]
    }
  ]
}