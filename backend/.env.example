# ─── Coindistro Backend Environment Variables ──────────
# This file contains the environment variables used by the backend.
# Copy this file to .env and adjust values as needed.

# Application
COINDISTRO_ENV=development
COINDISTRO_DEBUG=true
COINDISTRO_PORT=8080

# Database (PostgreSQL)
COINDISTRO_DB_HOST=localhost
COINDISTRO_DB_PORT=5432
COINDISTRO_DB_USER=coindistro
COINDISTRO_DB_PASSWORD=coindistro
COINDISTRO_DB_NAME=coindistro
COINDISTRO_DB_SSLMODE=disable

# Redis
COINDISTRO_REDIS_HOST=localhost
COINDISTRO_REDIS_PORT=6379
COINDISTRO_REDIS_PASSWORD=coindistro

# JWT Authentication
COINDISTRO_JWT_ACCESS_SECRET=change-me-in-production
COINDISTRO_JWT_REFRESH_SECRET=change-me-in-production-too
COINDISTRO_JWT_ACCESS_TTL=15
COINDISTRO_JWT_REFRESH_TTL=10080

# Logging
COINDISTRO_LOG_LEVEL=debug