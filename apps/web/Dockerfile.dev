# ─── Coindistro Development Dockerfile ──────────────
# Used by docker-compose.dev.yml for hot-reload development

FROM node:20-alpine

WORKDIR /app

# Install dependencies first for layer caching
COPY package.json package-lock.json* ./
RUN npm ci

# Source is bind-mounted for hot reload, so we only need node_modules here
# The actual src/ and public/ dirs are mounted at runtime via docker-compose.dev.yml

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true

EXPOSE 3000

# Dev server with hot reload
CMD ["npm", "run", "dev"]