{
  "name": "coindistro",
  "version": "0.2.0",
  "private": true,
  "description": "Coindistro — One Platform. Everything Crypto. All-in-one crypto financial ecosystem.",
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "lint": "npm run lint --prefix apps/web",
    "cds:storybook": "npm run storybook --workspace=@coindistro/cds",
    "cds:typecheck": "npm run typecheck --workspace=@coindistro/cds",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "vitest": "^4.1.10"
  }
}
