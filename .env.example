# ─── App ────────────────────────────────────────────
NODE_ENV=production

# ─── Database (PostgreSQL) ───────────────────────────
# Used by future api/admin services
DATABASE_URL=postgres://coindistro:coindistro@postgres:5432/coindistro

# ─── Redis ───────────────────────────────────────────
# Used by future services for caching, sessions, rate limiting
REDIS_URL=redis://redis:6379

# ─── External APIs ───────────────────────────────────
# Exchange API keys (future trading services)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# ─── Next.js ─────────────────────────────────────────
# Public-facing env vars (prefixed NEXT_PUBLIC_)
# NEXT_PUBLIC_SITE_URL=https://coindistro.com
# NEXT_PUBLIC_API_URL=https://api.coindistro.com

# ─── Auth (future) ───────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=